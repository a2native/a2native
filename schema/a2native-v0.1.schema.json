{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://a2native.github.io/schema/a2native-v0.1.schema.json",
  "title": "a2native Input Format (v0.1)",
  "description": "Input format for a2n — send this JSON to the a2native renderer to display a native UI form and collect user responses. This is a2native's own schema, conceptually inspired by the Google A2UI flat component model but adapted for synchronous stdin/stdout CLI use.",
  "type": "object",
  "required": ["components"],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "description": "Optional window title shown in the title bar."
    },
    "timeout": {
      "type": "integer",
      "minimum": 1,
      "description": "Auto-close the window after this many seconds. Output status will be 'timeout'."
    },
    "theme": {
      "type": "object",
      "description": "Optional visual theme overrides.",
      "additionalProperties": false,
      "properties": {
        "dark_mode": {
          "type": "boolean",
          "description": "Force dark (true) or light (false) mode. Defaults to system preference."
        },
        "accent_color": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$",
          "description": "Hex accent color, e.g. '#6C63FF'."
        }
      }
    },
    "components": {
      "type": "array",
      "description": "Ordered list of UI components to render.",
      "items": {
        "$ref": "#/$defs/Component"
      }
    }
  },
  "$defs": {
    "Component": {
      "oneOf": [
        { "$ref": "#/$defs/Text" },
        { "$ref": "#/$defs/Markdown" },
        { "$ref": "#/$defs/Code" },
        { "$ref": "#/$defs/Image" },
        { "$ref": "#/$defs/Divider" },
        { "$ref": "#/$defs/Alert" },
        { "$ref": "#/$defs/Link" },
        { "$ref": "#/$defs/Progress" },
        { "$ref": "#/$defs/TextField" },
        { "$ref": "#/$defs/Textarea" },
        { "$ref": "#/$defs/Password" },
        { "$ref": "#/$defs/Email" },
        { "$ref": "#/$defs/Url" },
        { "$ref": "#/$defs/NumberInput" },
        { "$ref": "#/$defs/DatePicker" },
        { "$ref": "#/$defs/TimePicker" },
        { "$ref": "#/$defs/DatetimePicker" },
        { "$ref": "#/$defs/DateRange" },
        { "$ref": "#/$defs/ColorPicker" },
        { "$ref": "#/$defs/Dropdown" },
        { "$ref": "#/$defs/Combobox" },
        { "$ref": "#/$defs/MultiSelect" },
        { "$ref": "#/$defs/Checkbox" },
        { "$ref": "#/$defs/Toggle" },
        { "$ref": "#/$defs/CheckboxGroup" },
        { "$ref": "#/$defs/RadioGroup" },
        { "$ref": "#/$defs/Slider" },
        { "$ref": "#/$defs/RangeSlider" },
        { "$ref": "#/$defs/Rating" },
        { "$ref": "#/$defs/Tags" },
        { "$ref": "#/$defs/FileUpload" },
        { "$ref": "#/$defs/Hidden" },
        { "$ref": "#/$defs/Button" },
        { "$ref": "#/$defs/Card" },
        { "$ref": "#/$defs/Row" },
        { "$ref": "#/$defs/Collapsible" },
        { "$ref": "#/$defs/Spacer" }
      ]
    },
    "SelectOption": {
      "type": "object",
      "required": ["value", "label"],
      "additionalProperties": false,
      "properties": {
        "value": { "type": "string" },
        "label": { "type": "string" }
      }
    },
    "Text": {
      "type": "object",
      "required": ["id", "type", "content"],
      "additionalProperties": false,
      "properties": {
        "id":      { "type": "string" },
        "type":    { "const": "text" },
        "content": { "type": "string", "description": "Plain text to display." }
      }
    },
    "Markdown": {
      "type": "object",
      "required": ["id", "type", "content"],
      "additionalProperties": false,
      "properties": {
        "id":      { "type": "string" },
        "type":    { "const": "markdown" },
        "content": {
          "type": "string",
          "description": "Markdown text. Supports: headings (#/##/###), **bold**, *italic*, `inline code`, [links](url), bullet lists (- or *), numbered lists (1. 2.), horizontal rules (---)."
        }
      }
    },
    "Image": {
      "type": "object",
      "required": ["id", "type", "src"],
      "additionalProperties": false,
      "properties": {
        "id":  { "type": "string" },
        "type": { "const": "image" },
        "src": { "type": "string", "description": "File path or URL." },
        "alt": { "type": "string", "description": "Alt text." }
      }
    },
    "Divider": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":   { "type": "string" },
        "type": { "const": "divider" }
      }
    },
    "TextField": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string" },
        "type":          { "const": "text-field" },
        "label":         { "type": "string" },
        "placeholder":   { "type": "string" },
        "required":      { "type": "boolean", "default": false },
        "default_value": { "type": "string" },
        "min_length":    { "type": "integer", "minimum": 0, "description": "Minimum character length." },
        "max_length":    { "type": "integer", "minimum": 0, "description": "Maximum character length." },
        "pattern":       { "type": "string", "description": "ECMAScript-compatible regular expression the value must match." },
        "error_message": { "type": "string", "description": "Custom error message shown when validation fails." }
      },
      "x-output": "string"
    },
    "Textarea": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string" },
        "type":          { "const": "textarea" },
        "label":         { "type": "string" },
        "placeholder":   { "type": "string" },
        "required":      { "type": "boolean", "default": false },
        "default_value": { "type": "string" },
        "min_length":    { "type": "integer", "minimum": 0, "description": "Minimum character length." },
        "max_length":    { "type": "integer", "minimum": 0, "description": "Maximum character length." },
        "pattern":       { "type": "string", "description": "ECMAScript-compatible regular expression the value must match." },
        "error_message": { "type": "string", "description": "Custom error message shown when validation fails." }
      },
      "x-output": "string"
    },
    "NumberInput": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string" },
        "type":          { "const": "number-input" },
        "label":         { "type": "string" },
        "min":           { "type": "number" },
        "max":           { "type": "number" },
        "step":          { "type": "number" },
        "default_value": { "type": "number" }
      },
      "x-output": "number"
    },
    "DatePicker": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string" },
        "type":          { "const": "date-picker" },
        "label":         { "type": "string" },
        "required":      { "type": "boolean", "default": false },
        "default_value": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "description": "YYYY-MM-DD" }
      },
      "x-output": "string (YYYY-MM-DD)"
    },
    "TimePicker": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string" },
        "type":          { "const": "time-picker" },
        "label":         { "type": "string" },
        "required":      { "type": "boolean", "default": false },
        "default_value": { "type": "string", "pattern": "^\\d{2}:\\d{2}$", "description": "HH:MM" }
      },
      "x-output": "string (HH:MM)"
    },
    "Dropdown": {
      "type": "object",
      "required": ["id", "type", "options"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string" },
        "type":          { "const": "dropdown" },
        "label":         { "type": "string" },
        "options":       { "type": "array", "items": { "$ref": "#/$defs/SelectOption" } },
        "required":      { "type": "boolean", "default": false },
        "default_value": { "type": "string" }
      },
      "x-output": "string"
    },
    "Checkbox": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string" },
        "type":          { "const": "checkbox" },
        "label":         { "type": "string" },
        "default_value": { "type": "boolean", "default": false }
      },
      "x-output": "boolean"
    },
    "CheckboxGroup": {
      "type": "object",
      "required": ["id", "type", "options"],
      "additionalProperties": false,
      "properties": {
        "id":             { "type": "string" },
        "type":           { "const": "checkbox-group" },
        "label":          { "type": "string" },
        "options":        { "type": "array", "items": { "$ref": "#/$defs/SelectOption" } },
        "default_values": { "type": "array", "items": { "type": "string" } }
      },
      "x-output": "string[] (selected values)"
    },
    "RadioGroup": {
      "type": "object",
      "required": ["id", "type", "options"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string" },
        "type":          { "const": "radio-group" },
        "label":         { "type": "string" },
        "options":       { "type": "array", "items": { "$ref": "#/$defs/SelectOption" } },
        "required":      { "type": "boolean", "default": false },
        "default_value": { "type": "string" }
      },
      "x-output": "string"
    },
    "Slider": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string" },
        "type":          { "const": "slider" },
        "label":         { "type": "string" },
        "min":           { "type": "number", "default": 0 },
        "max":           { "type": "number", "default": 100 },
        "step":          { "type": "number" },
        "default_value": { "type": "number" }
      },
      "x-output": "number"
    },
    "FileUpload": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":       { "type": "string" },
        "type":     { "const": "file-upload" },
        "label":    { "type": "string" },
        "accept":   { "type": "string", "description": "File type filter, e.g. '.pdf,.docx'" },
        "multiple": { "type": "boolean", "default": false }
      },
      "x-output": "string (file path; ';'-separated if multiple=true)"
    },
    "Button": {
      "type": "object",
      "required": ["id", "type", "label"],
      "additionalProperties": false,
      "properties": {
        "id":     { "type": "string" },
        "type":   { "const": "button" },
        "label":  { "type": "string" },
        "action": {
          "type": "string",
          "enum": ["submit", "cancel", "custom"],
          "default": "submit",
          "description": "'submit' ends the form and outputs values; 'cancel' closes with status 'cancelled'; 'custom' is reserved."
        }
      }
    },
    "Card": {
      "type": "object",
      "required": ["id", "type", "children"],
      "additionalProperties": false,
      "properties": {
        "id":       { "type": "string" },
        "type":     { "const": "card" },
        "title":    { "type": "string" },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/Component" },
          "description": "Nested components rendered inside the card."
        }
      }
    },
    "Row": {
      "type": "object",
      "required": ["id", "type", "children"],
      "additionalProperties": false,
      "properties": {
        "id":       { "type": "string" },
        "type":     { "const": "row" },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/Component" },
          "description": "Components rendered horizontally side-by-side in equal-width columns."
        }
      }
    },
    "Password": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string" },
        "type":          { "const": "password" },
        "label":         { "type": "string" },
        "placeholder":   { "type": "string" },
        "required":      { "type": "boolean", "default": false },
        "min_length":    { "type": "integer", "minimum": 0, "description": "Minimum character length." },
        "max_length":    { "type": "integer", "minimum": 0, "description": "Maximum character length." },
        "pattern":       { "type": "string", "description": "ECMAScript-compatible regular expression the value must match." },
        "error_message": { "type": "string", "description": "Custom error message shown when validation fails." }
      },
      "x-output": "string (not shown in output — warn users not to submit secrets)"
    },
    "Rating": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string" },
        "type":          { "const": "rating" },
        "label":         { "type": "string" },
        "max":           { "type": "integer", "minimum": 1, "maximum": 10, "default": 5, "description": "Maximum star count (default 5)." },
        "default_value": { "type": "integer", "minimum": 0 }
      },
      "x-output": "number (1–max, 0 if not rated)"
    },
    "Toggle": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string" },
        "type":          { "const": "toggle" },
        "label":         { "type": "string" },
        "default_value": { "type": "boolean", "default": false }
      },
      "x-output": "boolean"
    },
    "Code": {
      "type": "object",
      "required": ["id", "type", "content"],
      "additionalProperties": false,
      "properties": {
        "id":       { "type": "string" },
        "type":     { "const": "code" },
        "content":  { "type": "string", "description": "Source code to display (read-only)." },
        "language": { "type": "string", "description": "Optional language hint, e.g. 'rust', 'json'." }
      }
    },
    "Email": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string" },
        "type":          { "const": "email" },
        "label":         { "type": "string" },
        "placeholder":   { "type": "string" },
        "required":      { "type": "boolean", "default": false },
        "default_value": { "type": "string" },
        "error_message": { "type": "string" }
      },
      "x-output": "string (validated as email address)"
    },
    "Url": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string" },
        "type":          { "const": "url" },
        "label":         { "type": "string" },
        "placeholder":   { "type": "string" },
        "required":      { "type": "boolean", "default": false },
        "default_value": { "type": "string" },
        "error_message": { "type": "string" }
      },
      "x-output": "string (validated as http(s)/ftp URL)"
    },
    "Hidden": {
      "type": "object",
      "required": ["id", "type", "value"],
      "additionalProperties": false,
      "properties": {
        "id":    { "type": "string" },
        "type":  { "const": "hidden" },
        "value": { "description": "Arbitrary JSON value passed through verbatim to the output." }
      },
      "x-output": "verbatim value"
    },
    "DatetimePicker": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string" },
        "type":          { "const": "datetime-picker" },
        "label":         { "type": "string" },
        "required":      { "type": "boolean", "default": false },
        "default_value": { "type": "string", "description": "YYYY-MM-DD HH:MM" }
      },
      "x-output": "string (YYYY-MM-DD HH:MM)"
    },
    "DateRange": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string" },
        "type":          { "const": "date-range" },
        "label":         { "type": "string" },
        "required":      { "type": "boolean", "default": false },
        "default_start": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "default_end":   { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      },
      "x-output": "object { start, end }"
    },
    "ColorPicker": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string" },
        "type":          { "const": "color-picker" },
        "label":         { "type": "string" },
        "default_value": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
      },
      "x-output": "string (#RRGGBB)"
    },
    "RangeSlider": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string" },
        "type":        { "const": "range-slider" },
        "label":       { "type": "string" },
        "min":         { "type": "number", "default": 0 },
        "max":         { "type": "number", "default": 100 },
        "step":        { "type": "number" },
        "default_min": { "type": "number" },
        "default_max": { "type": "number" }
      },
      "x-output": "object { min, max }"
    },
    "MultiSelect": {
      "type": "object",
      "required": ["id", "type", "options"],
      "additionalProperties": false,
      "properties": {
        "id":             { "type": "string" },
        "type":           { "const": "multi-select" },
        "label":          { "type": "string" },
        "placeholder":    { "type": "string" },
        "options":        { "type": "array", "items": { "$ref": "#/$defs/SelectOption" } },
        "default_values": { "type": "array", "items": { "type": "string" } }
      },
      "x-output": "string[]"
    },
    "Combobox": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string" },
        "type":          { "const": "combobox" },
        "label":         { "type": "string" },
        "placeholder":   { "type": "string" },
        "options":       { "type": "array", "items": { "$ref": "#/$defs/SelectOption" } },
        "required":      { "type": "boolean", "default": false },
        "default_value": { "type": "string" }
      },
      "x-output": "string (typed or picked)"
    },
    "Tags": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":             { "type": "string" },
        "type":           { "const": "tags" },
        "label":          { "type": "string" },
        "placeholder":    { "type": "string" },
        "default_values": { "type": "array", "items": { "type": "string" } },
        "max":            { "type": "integer", "minimum": 1 }
      },
      "x-output": "string[]"
    },
    "Alert": {
      "type": "object",
      "required": ["id", "type", "content"],
      "additionalProperties": false,
      "properties": {
        "id":      { "type": "string" },
        "type":    { "const": "alert" },
        "kind":    { "type": "string", "enum": ["info", "success", "warning", "error"], "default": "info" },
        "title":   { "type": "string" },
        "content": { "type": "string" }
      }
    },
    "Link": {
      "type": "object",
      "required": ["id", "type", "label", "url"],
      "additionalProperties": false,
      "properties": {
        "id":    { "type": "string" },
        "type":  { "const": "link" },
        "label": { "type": "string" },
        "url":   { "type": "string", "format": "uri" }
      }
    },
    "Progress": {
      "type": "object",
      "required": ["id", "type", "value"],
      "additionalProperties": false,
      "properties": {
        "id":           { "type": "string" },
        "type":         { "const": "progress" },
        "label":        { "type": "string" },
        "value":        { "type": "number" },
        "max":          { "type": "number", "default": 1.0 },
        "show_percent": { "type": "boolean", "default": false }
      }
    },
    "Collapsible": {
      "type": "object",
      "required": ["id", "type", "title", "children"],
      "additionalProperties": false,
      "properties": {
        "id":       { "type": "string" },
        "type":     { "const": "collapsible" },
        "title":    { "type": "string" },
        "open":     { "type": "boolean", "default": true },
        "children": { "type": "array", "items": { "$ref": "#/$defs/Component" } }
      }
    },
    "Spacer": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id":   { "type": "string" },
        "type": { "const": "spacer" },
        "size": { "type": "number", "minimum": 0, "default": 8 }
      }
    }
  }
}
